# =============================================
# CONFIGURACIÓN DEL BOT DE TELEGRAM A FACEBOOK
# =============================================

# Token del bot de Telegram (desde @BotFather)
TELEGRAM_TOKEN=TU_TOKEN_DE_TELEGRAM_AQUI

# Credenciales de la App de Telegram para descargas sin límite (Telethon)
# Obtenlas en: https://my.telegram.org/apps
TELEGRAM_API_ID=TU_API_ID_AQUI
TELEGRAM_API_HASH=TU_API_HASH_AQUI

# Directorio temporal para almacenar videos durante la subida
TEMP_DIR=/tmp/fb_videos

# Duración mínima del video en segundos (1440 = 24 minutos)
MIN_VIDEO_DURATION=1440

# Tamaño máximo de video en bytes (10737418240 = 10 GB)
MAX_VIDEO_SIZE=10737418240
